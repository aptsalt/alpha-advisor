# Copy to .env and edit. Default provider is "mock" — runs with zero config.

# mock | ollama | azure
ALPHA_PROVIDER=mock

# ── Ollama (local models) ─────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:32b
OLLAMA_EMBED_MODEL=embedding:latest

# ── Azure OpenAI (production target named in the ALPHA Wealth JD) ─────────────
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# ── Policy knobs ──────────────────────────────────────────────────────────────
ALPHA_TOP_K=4
ALPHA_MAX_RETRIES=2
ALPHA_CONCENTRATION_LIMIT=0.25
